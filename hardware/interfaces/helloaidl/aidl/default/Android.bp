cc_binary {
    name: "android.hardware.helloaidl.service",
    relative_install_path: "hw",
    vendor: true,
    shared_libs: [
        "libbinder_ndk",
        "liblog",
        "libbase",
        "libcutils",
        "libutils",
        "android.hardware.helloaidl-V1-ndk",
    ],
    vintf_fragments: [
        "android.hardware.helloaidl.default.xml",
    ],
    srcs: [
        "DeviceStatusManagerImpl.cpp",
        "main.cpp",
    ],
    init_rc: ["android.hardware.helloaidl.rc"],
}