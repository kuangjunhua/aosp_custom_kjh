type hellohidl_dt, domain;
type hellohidl_dt_exec, exec_type, vendor_file_type,file_type;
type hellohidl_hwservice, hwservice_manager_type;
hwbinder_use(hellohidl_dt);
init_daemon_domain(hellohidl_dt)

add_hwservice(hellohidl_dt, hellohidl_hwservice)

domain_auto_trans(shell, hellohidl_dt_exec, hellohidl_dt)
allow hellohidl_dt hwservicemanager_prop:file {map read open getattr};
allow hellohidl_dt system_file:dir {read open getattr search};
